{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/favicon.ico", "dest": "/public/images/favicon.ico" },
    { "src": "/(.*\\.(css|js|jpeg|jpg|png|svg|ico|webp|woff2?))", "dest": "/public/$1" },
    { "src": "/(index\\.html)?", "dest": "/public/index.html" },
    { "src": "/livreur", "dest": "/public/livreur.html" },
    { "src": "/adv", "dest": "/public/adv.html" },
    { "src": "/admin", "dest": "/public/admin.html" }
  ]
}
